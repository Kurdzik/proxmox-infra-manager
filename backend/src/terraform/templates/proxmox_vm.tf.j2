terraform {
  required_providers {
    proxmox = {
      source  = "bpg/proxmox"
      version = "~> 0.66"
    }
  }
}

provider "proxmox" {
  endpoint  = "{{ proxmox_url }}"
  api_token = "{{ api_token }}"
  insecure  = {{ insecure | lower }}

  ssh {
    agent    = false
    username = "{{ ssh_username }}"
    password = "{{ ssh_password }}"
  }
}

{% if install_guest_agent %}
resource "proxmox_virtual_environment_file" "cloud_init_agent" {
  content_type = "snippets"
  datastore_id = "local"
  node_name    = "{{ node_name }}"

  source_raw {
    data      = "#cloud-config\npackages:\n  - qemu-guest-agent\nruncmd:\n  - systemctl enable qemu-guest-agent\n  - systemctl start qemu-guest-agent\n"
    file_name = "cloud-init-agent-{{ vmid }}.yaml"
  }
}

{% endif %}
resource "proxmox_virtual_environment_vm" "vm" {
  name      = "{{ vm_name }}"
  node_name = "{{ node_name }}"
  vm_id     = {{ vmid }}

  scsi_hardware = "virtio-scsi-pci"
  boot_order    = ["scsi0"]

  operating_system {
    type = "l26"
  }

  cpu {
    cores = {{ cpu_cores }}
    type  = "host"
  }

  memory {
    dedicated = {{ memory_mb }}
  }

  # Serial console — required by Debian/Ubuntu cloud images for cloud-init datasource discovery
  serial_device {}

  vga {
    type = "serial0"
  }

  disk {
    datastore_id = "local-lvm"
    file_id      = "local:iso/{{ image_filename }}"
    interface    = "scsi0"
    size         = {{ disk_gb }}
    discard      = "on"
  }

  network_device {
    bridge = "{{ bridge }}"
    model  = "virtio"
  }

{% if install_guest_agent %}
  # Upload a cloud-init snippet that installs qemu-guest-agent on first boot
  # so the Proxmox exec API can be used to configure the VM after provisioning.
{% endif %}

  initialization {
    datastore_id = "local"

    ip_config {
      ipv4 {
{% if static_ip and gateway and prefix_len %}
        address = "{{ static_ip }}/{{ prefix_len }}"
        gateway = "{{ gateway }}"
{% else %}
        address = "dhcp"
{% endif %}
      }
    }
    user_account {
      username = "{{ cloud_init_user }}"
      password = "{{ console_password }}"
      keys     = [{% for key in ssh_public_keys %}"{{ key }}"{% if not loop.last %}, {% endif %}{% endfor %}]
    }
{% if install_guest_agent %}
    user_data_file_id = proxmox_virtual_environment_file.cloud_init_agent.id
{% endif %}
  }

  agent {
    enabled = {{ "true" if install_guest_agent else "false" }}
  }
}

output "vm_ipv4" {
  value = try(proxmox_virtual_environment_vm.vm.ipv4_addresses[1][0], null)
}
