terraform {
  required_providers {
    proxmox = {
      source  = "bpg/proxmox"
      version = "~> 0.66"
    }
  }
}

provider "proxmox" {
  endpoint  = "{{ proxmox_url }}"
  api_token = "{{ api_token }}"
  insecure  = {{ insecure | lower }}

  ssh {
    agent    = false
    username = "{{ ssh_username }}"
    password = "{{ ssh_password }}"
  }
}

resource "proxmox_virtual_environment_vm" "vm" {
  name      = "{{ vm_name }}"
  node_name = "{{ node_name }}"
  vm_id     = {{ vmid }}

  scsi_hardware = "virtio-scsi-pci"
  boot_order    = ["scsi0"]

  operating_system {
    type = "l26"
  }

  cpu {
    cores = {{ cpu_cores }}
    type  = "host"
  }

  memory {
    dedicated = {{ memory_mb }}
  }

  # Serial console — required by Debian/Ubuntu cloud images for cloud-init datasource discovery
  serial_device {}

  vga {
    type = "serial0"
  }

  disk {
    datastore_id = "local-lvm"
    file_id      = "local:iso/{{ image_filename }}"
    interface    = "scsi0"
    size         = {{ disk_gb }}
    discard      = "on"
  }

  network_device {
    bridge = "{{ bridge }}"
    model  = "virtio"
  }

  initialization {
    datastore_id = "local"

    ip_config {
      ipv4 {
{% if static_ip and gateway and prefix_len %}
        address = "{{ static_ip }}/{{ prefix_len }}"
        gateway = "{{ gateway }}"
{% else %}
        address = "dhcp"
{% endif %}
      }
    }
    user_account {
      username = "{{ cloud_init_user }}"
      password = "{{ console_password }}"
      keys     = [{% for key in ssh_public_keys %}"{{ key }}"{% if not loop.last %}, {% endif %}{% endfor %}]
    }
  }

  agent {
    enabled = false
  }
}

output "vm_ipv4" {
  value = try(proxmox_virtual_environment_vm.vm.ipv4_addresses[1][0], null)
}
